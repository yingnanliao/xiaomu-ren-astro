---
const MAPS_URL = 'https://www.google.com/maps/search/?api=1&query=台中市霧峰區新生路126號光復新村';

const categories = [
  {
    name: '羊奶特調飲品', icon: '🥛',
    items: [
      { name:'純羊奶',     price:75,  hot:true },
      { name:'冬瓜羊奶',   price:50 },
      { name:'厚奶茶',     price:60 },
      { name:'芝麻羊奶',   price:60 },
      { name:'燕麥羊奶',   price:60 },
      { name:'巧克力羊奶', price:60 },
      { name:'羊奶咖啡',   price:130, note:'320cc' },
    ],
  },
  {
    name: '羊奶饅頭', icon: '🫓',
    items: [
      { name:'原味', price:50 },
      { name:'黑糖', price:50 },
      { name:'紅麴', price:50 },
      { name:'南瓜', price:50 },
      { name:'黎麥', price:50 },
    ],
  },
  {
    name: '羊奶甜點', icon: '🍮',
    items: [
      { name:'羊奶布丁', price:65, hot:true },
      { name:'羊奶雪糕', price:50 },
    ],
  },
];
---

<section id="menu" style="background:var(--color-bg-2); border-top:1px solid var(--color-border);">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-12 py-16 sm:py-20">

    <!-- 標題 -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-10 sm:mb-14 reveal">
      <div>
        <span class="tag">Price Menu</span>
        <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-black" style="color:var(--color-ink);">
          熱賣產品<br/>
          <span style="color:var(--color-sage);">價目表</span>
        </h2>
      </div>
      <p class="text-sm leading-loose" style="color:var(--color-ink-muted); max-width:28ch;">
        光復新村門市現場購買<br/>
        所有品項均以自家當日鮮奶製作
      </p>
    </div>

    <!-- 價目三欄（手機：單欄堆疊；桌面：三欄並排） -->
    <div class="grid grid-cols-1 lg:grid-cols-3 overflow-hidden"
      style="border:1px solid var(--color-border);">
      {categories.map((cat, ci) => (
        <div class={`${ci > 0 ? 'border-t lg:border-t-0 lg:border-l' : ''}`}
          style="border-color:var(--color-border);">
          <!-- 分類頭 -->
          <div class="px-6 py-4 flex items-center gap-3"
            style="background:var(--color-ink); border-bottom:1px solid var(--color-border);">
            <span class="text-xl">{cat.icon}</span>
            <span class="text-sm font-black tracking-wider uppercase"
              style="color:var(--color-bg);">{cat.name}</span>
          </div>
          <!-- 品項 -->
          <div style="background:white;">
            {cat.items.map((item, ii) => (
              <div class={`flex items-center justify-between px-6 py-4 ${ii < cat.items.length-1 ? 'border-b' : ''}`}
                style="border-color:var(--color-border);">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-sm font-medium" style="color:var(--color-ink);">{item.name}</span>
                  {item.note && <span class="text-xs" style="color:var(--color-ink-muted);">({item.note})</span>}
                  {(item as any).hot && (
                    <span class="px-1.5 py-0.5 text-[10px] font-black tracking-wider"
                      style="background:var(--color-gold); color:var(--color-ink);">HOT</span>
                  )}
                </div>
                <span class="text-base font-black flex-shrink-0 ml-4"
                  style="color:var(--color-ink); font-family:var(--font-serif);">
                  ${item.price}
                </span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 底部資訊 -->
    <div class="mt-6 sm:mt-8 flex flex-col sm:flex-row flex-wrap items-start sm:items-center gap-3 sm:gap-5 reveal">
      <a href={MAPS_URL} target="_blank" rel="noopener"
        class="flex items-start gap-2 text-xs transition-colors group"
        style="color:var(--color-ink-muted);"
        onmouseover="this.style.color='var(--color-sage)'"
        onmouseout="this.style.color='var(--color-ink-muted)'">
        <svg class="mt-0.5 flex-shrink-0" width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        台中市霧峰區新生路 126 號（光復新村）
      </a>
      <span class="hidden sm:block" style="color:var(--color-border)">|</span>
      <a href="tel:0918620092" class="flex items-center gap-2 text-xs transition-colors"
        style="color:var(--color-ink-muted);"
        onmouseover="this.style.color='var(--color-sage)'"
        onmouseout="this.style.color='var(--color-ink-muted)'">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        0918-620-092
      </a>
      <span class="hidden sm:block" style="color:var(--color-border)">|</span>
      <button data-line-modal
        class="flex items-center gap-2 text-xs font-bold tracking-wider uppercase transition-colors"
        style="color:var(--color-sage);"
        onmouseover="this.style.color='var(--color-ink)'"
        onmouseout="this.style.color='var(--color-sage)'">
        LINE 宅配訂購 →
      </button>
    </div>
  </div>
</section>
