---
const year = new Date().getFullYear();
const links = [
  { label:'關於我們', href:'#about' },
  { label:'產品價目', href:'#menu' },
  { label:'近期活動', href:'#events' },
  { label:'羊奶小學堂', href:'#faq' },
  { label:'品牌故事', href:'#timeline' },
];
const hours = [
  { day:'週一', time:'休息', closed:true },
  { day:'週二 — 週五', time:'13:00 – 16:00' },
  { day:'週六', time:'12:00 – 17:30' },
  { day:'週日', time:'12:30 – 17:30' },
];
const MAPS_URL = 'https://www.google.com/maps/search/?api=1&query=台中市霧峰區新生路126號光復新村';
const FB_URL   = 'https://www.facebook.com/p/%E5%B0%8F%E7%89%A7%E4%BA%BA%E7%BE%8A%E5%A5%B6-100057143992346/';
const IG_URL   = 'https://www.instagram.com/little_shepherd_goat_milk/';
---

<footer id="contact">

  <!-- ── CTA 橫條 ── -->
  <div class="py-14 px-6 lg:px-12" style="background:var(--color-sage-pale); border-top:1px solid var(--color-border);">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div class="reveal-left">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black"
          style="color:var(--color-ink); font-family:var(--font-serif);">
          準備好喝一口純粹了嗎？
        </h2>
        <p class="mt-1.5 text-sm" style="color:var(--color-ink-muted);">
          首購優惠 · 宅配到府 · 全台灣服務
        </p>
      </div>
      <div class="reveal-right flex flex-wrap gap-3">
        <button data-line-modal class="btn-dark">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
          </svg>
          加 LINE 訂購
        </button>
        <a href={MAPS_URL} target="_blank" rel="noopener" class="btn-outline-dark">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          導航前往
        </a>
      </div>
    </div>
  </div>

  <!-- ── 頁尾主體 ── -->
  <div class="py-14 px-6 lg:px-12" style="background:var(--color-bg-dark);">
    <div class="max-w-7xl mx-auto">

      <!-- 上半：品牌 + 導覽 + 時間 -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 pb-10"
        style="border-bottom:1px solid rgba(255,255,255,.07);">

        <!-- 品牌欄 -->
        <div class="sm:col-span-2">
          <!-- Logo：顯示於深色背景，使用白底badge形式 -->
          <div class="inline-block mb-5 p-2.5 rounded"
            style="background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1);">
            <img src="/logo.png" alt="小牧人羊奶" class="h-10 w-auto" />
          </div>

          <p class="text-sm leading-loose" style="color:rgba(255,255,255,.35); max-width:28ch;">
            台灣台中霧峰光復新村<br/>
            用十年光陰，換一杯最純粹的滋味
          </p>

          <!-- 社群圖示列 -->
          <div class="mt-5 flex items-center gap-3">
            <!-- Facebook -->
            <a href={FB_URL} target="_blank" rel="noopener" aria-label="Facebook"
              class="w-9 h-9 rounded flex items-center justify-center transition-all duration-200"
              style="background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1);"
              onmouseover="this.style.background='#1877F2'; this.style.borderColor='#1877F2'"
              onmouseout="this.style.background='rgba(255,255,255,0.07)'; this.style.borderColor='rgba(255,255,255,0.1)'">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="white">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>

            <!-- Instagram -->
            <a href={IG_URL} target="_blank" rel="noopener" aria-label="Instagram"
              class="w-9 h-9 rounded flex items-center justify-center transition-all duration-200"
              style="background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1);"
              onmouseover="this.style.background='#E1306C'; this.style.borderColor='#E1306C'"
              onmouseout="this.style.background='rgba(255,255,255,0.07)'; this.style.borderColor='rgba(255,255,255,0.1)'">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="white">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>

            <!-- LINE -->
            <button data-line-modal aria-label="LINE"
              class="w-9 h-9 rounded flex items-center justify-center transition-all duration-200"
              style="background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1);"
              onmouseover="this.style.background='#06C755'; this.style.borderColor='#06C755'"
              onmouseout="this.style.background='rgba(255,255,255,0.07)'; this.style.borderColor='rgba(255,255,255,0.1)'">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="white">
                <path d="M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- 導覽連結 -->
        <div>
          <h4 class="text-xs font-black tracking-[.2em] uppercase mb-4"
            style="color:rgba(255,255,255,.2);">頁面導覽</h4>
          <ul class="space-y-2.5">
            {links.map(l => (
              <li>
                <a href={l.href} class="text-sm transition-colors"
                  style="color:rgba(255,255,255,.4);"
                  onmouseover="this.style.color='var(--color-gold)'"
                  onmouseout="this.style.color='rgba(255,255,255,.4)'">{l.label}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- 聯絡 + 時間 -->
        <div>
          <h4 class="text-xs font-black tracking-[.2em] uppercase mb-4"
            style="color:rgba(255,255,255,.2);">聯絡資訊</h4>

          <!-- 地址（可點擊 Google Maps） -->
          <a href={MAPS_URL} target="_blank" rel="noopener"
            class="flex items-start gap-2 text-xs leading-relaxed mb-3 transition-colors group"
            style="color:rgba(255,255,255,.4);"
            onmouseover="this.style.color='var(--color-gold)'"
            onmouseout="this.style.color='rgba(255,255,255,.4)'">
            <svg class="mt-0.5 flex-shrink-0" width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            台中市霧峰區新生路 126 號<br/>（光復新村）
          </a>

          <a href="tel:0918620092"
            class="flex items-center gap-2 text-xs mb-5 transition-colors"
            style="color:rgba(255,255,255,.4);"
            onmouseover="this.style.color='var(--color-gold)'"
            onmouseout="this.style.color='rgba(255,255,255,.4)'">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            0918-620-092
          </a>

          <div style="border-top:1px solid rgba(255,255,255,.07); padding-top:1rem;">
            <h4 class="text-xs font-black tracking-[.2em] uppercase mb-3"
              style="color:rgba(255,255,255,.2);">營業時間</h4>
            <ul class="space-y-2">
              {hours.map(h => (
                <li class="flex justify-between gap-3 text-xs"
                  style={`color:${h.closed ? 'rgba(255,255,255,.18)' : 'rgba(255,255,255,.4)'}`}>
                  <span>{h.day}</span>
                  <span class={h.closed ? 'line-through' : ''}>{h.time}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- 版權 -->
      <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs"
        style="color:rgba(255,255,255,.18);">
        <span>© {year} 小牧人羊奶 Little Shepherd Goat Milk · All Rights Reserved</span>
        <span>台灣製造 · 用心牧養</span>
      </div>
    </div>
  </div>
</footer>
